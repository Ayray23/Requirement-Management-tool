{
  "name": "remt-final-year-project",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "functions"
  ],
  "scripts": {
    "dev": "npm run dev --workspace client",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server",
    "check": "npm run check --workspace server",
    "check:functions": "npm run check --workspace functions",
    "check:all": "npm run check && npm run check:functions"
  },
  "engines": {
    "node": "20.x"
  }
}
